# BehaviorShield Environment Configuration
# Copy this file to .env and adjust as needed.

# Flask settings
FLASK_SECRET_KEY=change-me-in-production
FLASK_ENV=development

# Database path (absolute)
DB_PATH=C:/BehaviorShield/data/behaviorshield.db

# Learning mode duration (days)
LEARNING_MODE_DAYS=7

# Port for the backend API
FLASK_PORT=5000

# VirusTotal API Key (Threat Intelligence)
VT_API_KEY=your_virustotal_api_key_here
